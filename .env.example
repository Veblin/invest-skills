# ============================================================
# invest-A 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际的 Key
#   cp .env.example .env
#
# 所有 Key 均为可选。不配置时使用免费数据源（akshare/efinance/
# yfinance/WebSearch），报告会标注降级情况。
# ============================================================

# ------------------------------------------------------------------
# A 股/港股数据
# ------------------------------------------------------------------

# Tushare Pro Token（可选）
# 注册即送 120 积分（可调用部分基础接口）
# 进阶使用：充值至 2000 积分（≈200 元）解锁主要数据接口
# 注册地址：https://tushare.pro
# 学生免费申请额外积分：加入学生QQ群 290541801
TUSHARE_TOKEN=

# Longbridge Token（可选，港股/美股兜底）
# 需 OAuth 配置，OpenAPI 文档: https://open.longbridge.com
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=

# ------------------------------------------------------------------
# 全球宏观数据
# ------------------------------------------------------------------

# FRED API Key（推荐配置，免费注册）
# 联邦储备经济数据库，816K+ 宏观经济时间序列
# 注册后配额从 30 提升至 120 次/分钟
# 注册地址：https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ------------------------------------------------------------------
# 新闻搜索
# ------------------------------------------------------------------

# Tavily Search API Key（可选，免费 1000 次/月）
# 注册地址：https://tavily.com
TAVILY_API_KEY=

# Bocha 中文搜索 API Key（可选，免费 1000 次试用）
# 中文财经内容覆盖优于 Tavily
# 注册地址：https://open.bocha.cn
BOCHA_API_KEY=

# ------------------------------------------------------------------
# 可选增强
# ------------------------------------------------------------------

# Finnhub API Key（可选，美股数据，免费 60 次/分钟）
# 注册地址：https://finnhub.io
FINNHUB_API_KEY=

# AlphaVantage API Key（可选，美股数据，免费 25 次/天）
# 注册地址：https://www.alphavantage.co
ALPHAVANTAGE_API_KEY=

# ------------------------------------------------------------------
# GitHub Actions — PR AI Code Review（仅 CI，勿写入本地 .env）
# ------------------------------------------------------------------
# 默认 provider: deepseek（性价比最高，代码审查够用）
#   Secret: DEEPSEEK_API_KEY — https://platform.deepseek.com
#
# 可选 provider（Repository variable: AI_REVIEW_PROVIDER）:
#   gemini     — GEMINI_API_KEY，模型默认 gemini-2.0-flash（有免费额度）
#   openai     — OPENAI_API_KEY，模型默认 gpt-4o-mini
#   openrouter — OPENROUTER_API_KEY，可路由到多种低价模型
#   anthropic  — ANTHROPIC_API_KEY（较贵，不推荐日常使用）
#
# 通用 fallback: AI_REVIEW_API_KEY（任意 provider 均可）
# 可选变量: AI_REVIEW_MODEL（覆盖默认模型名）
