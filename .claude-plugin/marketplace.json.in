    },
    {
      "name": "invest:a-limit-up",
      "description": "A股涨停板全市场扫描+交互式深挖。盘面宽度/板块轮动/涨停归因，支持质量过滤与交互筛选。学习工具，非决策工具。",
      "version": "{{ VERSION }}",
